{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": ["copilot", "claudecode", "codexcli"],
  "features": ["rules", "ignore", "mcp", "commands", "subagents", "skills"],
  "outputRoots": ["."],
  "delete": true,
  "verbose": true,
  "global": true,
  "modularMcp": true,
}
